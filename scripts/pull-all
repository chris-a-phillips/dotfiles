#!/usr/bin/env bash

set -u

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
if [[ -f "$SCRIPT_DIR/_utils" ]]; then
  # shellcheck source=/dev/null
  . "$SCRIPT_DIR/_utils"
elif command -v _utils >/dev/null 2>&1; then
  # shellcheck source=/dev/null
  . _utils
fi

: "${RED:=}"
: "${GREEN:=}"
: "${YELLOW:=}"
: "${BLUE:=}"
: "${CYAN:=}"
: "${NC:=}"
: "${BBLUE:=$BLUE}"

updated_count=0
skipped_count=0
failed_count=0
total_repos=0

usage() {
  cat <<'EOF'
Usage: pull-all [directory]

Pull each direct child git repository under directory.
Defaults to the current directory.

Only clean repositories with an upstream branch are pulled.
Pulls use --ff-only so the script never creates merge commits.
EOF
}

print_status() {
  local color="$1"
  local status="$2"
  local message="$3"
  printf '%b%-8s%b %s\n' "$color" "$status" "$NC" "$message"
}

is_git_repo() {
  [[ "$(git -C "$1" rev-parse --is-inside-work-tree 2>/dev/null)" == "true" ]]
}

current_branch() {
  git -C "$1" branch --show-current 2>/dev/null
}

upstream_branch() {
  git -C "$1" rev-parse --abbrev-ref --symbolic-full-name '@{u}' 2>/dev/null
}

has_uncommitted_changes() {
  [[ -n "$(git -C "$1" status --porcelain 2>/dev/null)" ]]
}

has_unpushed_commits() {
  local repo_path="$1"
  local upstream="$2"

  git -C "$repo_path" rev-list --count "$upstream"..HEAD 2>/dev/null | grep -q -v '^0$'
}

update_repo() {
  local repo_path="$1"
  local repo_name
  local branch
  local upstream

  repo_name="$(basename "$repo_path")"

  if ! is_git_repo "$repo_path"; then
    return 3
  fi

  ((total_repos++))

  branch="$(current_branch "$repo_path")"
  if [[ -z "$branch" ]]; then
    print_status "$YELLOW" "SKIP" "$repo_name is detached"
    ((skipped_count++))
    return 0
  fi

  upstream="$(upstream_branch "$repo_path")"
  if [[ -z "$upstream" ]]; then
    print_status "$YELLOW" "SKIP" "$repo_name:$branch has no upstream"
    ((skipped_count++))
    return 0
  fi

  if has_uncommitted_changes "$repo_path"; then
    print_status "$YELLOW" "SKIP" "$repo_name:$branch has uncommitted changes"
    ((skipped_count++))
    return 0
  fi

  printf 'Checking %s:%s... ' "$repo_name" "$branch"

  if ! git -C "$repo_path" fetch --quiet --prune; then
    printf '%bFAILED%b fetch failed\n' "$RED" "$NC"
    ((failed_count++))
    return 1
  fi

  if has_unpushed_commits "$repo_path" "$upstream"; then
    printf '%bSKIP%b has unpushed commits\n' "$YELLOW" "$NC"
    ((skipped_count++))
    return 0
  fi

  if git -C "$repo_path" pull --ff-only --quiet; then
    printf '%bDONE%b\n' "$GREEN" "$NC"
    ((updated_count++))
    return 0
  fi

  printf '%bFAILED%b pull failed\n' "$RED" "$NC"
  ((failed_count++))
  return 1
}

main() {
  local root="${1:-.}"
  local repo
  local found_child=0

  case "$root" in
    -h|--help)
      usage
      return 0
      ;;
  esac

  if [[ ! -d "$root" ]]; then
    printf '%berror:%b directory not found: %s\n' "$RED" "$NC" "$root" >&2
    return 1
  fi

  root="$(cd "$root" && pwd)"

  printf '%bUpdating git repositories under:%b %s\n' "$BBLUE" "$NC" "$root"
  printf '%s\n' "=========================================="

  for repo in "$root"/*; do
    [[ -d "$repo" ]] || continue
    found_child=1
    update_repo "$repo" || true
  done

  if [[ "$found_child" -eq 0 ]]; then
    print_status "$YELLOW" "SKIP" "no child directories found"
  fi

  printf '\n%bSummary:%b\n' "$BBLUE" "$NC"
  printf '%bUpdated:%b %d\n' "$GREEN" "$NC" "$updated_count"
  printf '%bSkipped:%b %d\n' "$YELLOW" "$NC" "$skipped_count"
  if [[ "$failed_count" -gt 0 ]]; then
    printf '%bFailed:%b %d\n' "$RED" "$NC" "$failed_count"
  fi
  printf '%bRepositories found:%b %d\n' "$CYAN" "$NC" "$total_repos"

  [[ "$failed_count" -eq 0 ]]
}

main "$@"
